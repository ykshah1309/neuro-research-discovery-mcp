# Copy to .env and fill in real values. Both keys are optional.

# NCBI Entrez API key. With a key, PubMed rate limit raises from 3 req/sec to 10 req/sec.
# Get one free at https://www.ncbi.nlm.nih.gov/account/  →  Settings  →  API Key Management.
PUBMED_API_KEY=

# Contact email NCBI requires for Entrez. Falls back to a generic placeholder if unset
# but you should set this so NCBI can reach you if something is wrong with your traffic.
PUBMED_EMAIL=

# How many seconds collections-index cache stays warm for NeuroVault (DOI reverse lookup).
# Default 86400 (24 h). Lower for fresher results; higher for fewer page-35 cold starts.
# NEUROVAULT_INDEX_TTL=86400

# Production opt-in: refuse to start the server when PUBMED_EMAIL is the
# placeholder. Recommended for any deployment that talks to NCBI under load,
# since NCBI may block traffic from unidentified instances at 429 time
# rather than at startup. Default: off (warn-only).
# NEURO_REQUIRE_PUBMED_EMAIL=1
